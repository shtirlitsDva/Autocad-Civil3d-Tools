<Window x:Class="IntersectUtilities.BatchProcessing.BPUIv2.UI.FilterEditor.FilterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IntersectUtilities.BatchProcessing.BPUIv2.UI.FilterEditor"
        xmlns:core="clr-namespace:IntersectUtilities.BatchProcessing.BPUIv2.Core"
        Title="Filter Editor"
        Width="650" Height="500"
        MinWidth="500" MinHeight="350"
        Style="{DynamicResource DialogWindowStyle}"
        Background="{DynamicResource Background}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../../CmdUI/UI/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Add Group"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding AddGroupCommand}"
                    Padding="12,5"
                    Margin="0,0,8,0"/>
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnOkClick"
                    Padding="20,5"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnCancelClick"
                    Padding="20,5"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="Entity Filter Groups"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text}"
                   Margin="0,0,0,4"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="Groups are combined with OR logic. Conditions within a group use AND logic."
                   Foreground="#FF808080" FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="— OR —"
                                       HorizontalAlignment="Center"
                                       Foreground="#FF808080"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       Margin="0,6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding
                                                RelativeSource={RelativeSource PreviousData}}"
                                                Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Background="{DynamicResource DarkRowBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    Margin="0,0,0,4">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                        <TextBlock Text="Filter Group (AND)"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text}"
                                                   FontSize="12"/>
                                        <Button Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="10"
                                                HorizontalAlignment="Right"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.RemoveGroupCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove group"
                                                Width="26" Height="26"/>
                                    </Grid>

                                    <Button DockPanel.Dock="Bottom"
                                            Content="+ Add Condition"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding AddConditionCommand}"
                                            Padding="8,3"
                                            HorizontalAlignment="Left"
                                            Margin="0,6,0,0"
                                            FontSize="11"/>

                                    <ItemsControl ItemsSource="{Binding Conditions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox Grid.Column="0"
                                                              ItemsSource="{Binding DataContext.AvailableProperties,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Property}"
                                                              Style="{StaticResource ModernDarkComboBox}"
                                                              Margin="0,0,4,0"/>

                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{Binding DataContext.AvailableOperators,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Operator}"
                                                              Style="{StaticResource ModernDarkComboBox}"
                                                              Margin="0,0,4,0"/>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FormTextBoxStyle}"
                                                             Margin="0,0,4,0"/>

                                                    <Button Grid.Column="3"
                                                            Content="&#xE74D;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="10"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Command="{Binding DataContext.RemoveConditionCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl,
                                                                    AncestorLevel=2}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Remove condition"
                                                            Width="26" Height="26"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
