<Window x:Class="IntersectUtilities.BatchProcessing.BPUIv2.UI.DrawingList.DrawingListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Manage Drawing List"
        Width="620" Height="520"
        MinWidth="500" MinHeight="400"
        Style="{DynamicResource DialogWindowStyle}"
        Background="{DynamicResource Background}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary Source="../../../../CmdUI/UI/Theme.xaml"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Folder Scanning Section -->
        <GroupBox Grid.Row="0"
                  Header="Scan Folder"
                  Style="{StaticResource ModernGroupBox}"
                  Margin="0,0,0,4">
            <StackPanel Margin="4">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             Background="{DynamicResource DarkRowBackground}"
                             Foreground="{DynamicResource Text}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Padding="6,4"/>
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseFolderCommand}"
                            Padding="12,4"
                            Margin="6,0,0,0"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="File mask:"
                               Foreground="{DynamicResource Text}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding FileMask, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             Background="{DynamicResource DarkRowBackground}"
                             Foreground="{DynamicResource Text}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Padding="6,4"/>
                    <CheckBox Grid.Column="2"
                              Content="Include subfolders"
                              IsChecked="{Binding IncludeSubfolders}"
                              Style="{StaticResource FormCheckBoxStyle}"
                              Margin="12,0,0,0"/>
                    <Button Grid.Column="4"
                            Content="Scan Folder"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ScanFolderCommand}"
                            Padding="12,4"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Import / Add Section -->
        <GroupBox Grid.Row="1"
                  Header="Import / Add"
                  Style="{StaticResource ModernGroupBox}"
                  Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Button Content="Import .txt..."
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ImportTextFileCommand}"
                        Padding="12,4"
                        Margin="0,0,8,0"/>
                <Button Content="Add Files..."
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding AddFilesCommand}"
                        Padding="12,4"/>
            </StackPanel>
        </GroupBox>

        <!-- Drawing List DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DrawingItems}"
                  Style="{StaticResource DarkDataGridStyle}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionUnit="FullRow"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="28"
                  Margin="0,0,0,4">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header=""
                                        Binding="{Binding IsIncluded, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                        Width="40"/>
                <DataGridTextColumn Header="File Name"
                                    Binding="{Binding FileName}"
                                    IsReadOnly="True"
                                    Width="180"/>
                <DataGridTextColumn Header="File Path"
                                    Binding="{Binding FilePath}"
                                    IsReadOnly="True"
                                    Width="*"/>
                <DataGridTemplateColumn Header="Exists" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="10" Height="10"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                <Setter Property="Fill" Value="#FFF44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Toolbar -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Select All"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SelectAllCommand}"
                    Padding="10,4"
                    Margin="0,0,6,0"/>
            <Button Grid.Column="1"
                    Content="Deselect All"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding DeselectAllCommand}"
                    Padding="10,4"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding Summary}"
                       Foreground="{DynamicResource Text}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"/>
        </Grid>

        <!-- Dialog Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Style="{StaticResource DialogButtonStyle}"
                    Click="OnOkClick"
                    IsDefault="True"/>
            <Button Content="Cancel"
                    Style="{StaticResource DialogButtonStyle}"
                    Click="OnCancelClick"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
