<Window x:Class="IntersectUtilities.BatchProcessing.BPUIv2.UI.InputsDialog.InputsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sequence Inputs"
        Width="700" Height="500"
        MinWidth="550" MinHeight="350"
        Style="{DynamicResource DialogWindowStyle}"
        Background="{DynamicResource Background}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../../CmdUI/UI/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnOkClick"
                    Padding="20,5"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnCancelClick"
                    Padding="20,5"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="Configure Inputs"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text}"
                   Margin="0,0,0,4"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="Edit parameter values for each step. Bound parameters are read-only."
                   Foreground="#FF808080" FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Inputs}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource DarkHeaderBackground}"
                                        Padding="8,5"
                                        Margin="0,8,0,2"
                                        CornerRadius="3">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="{DynamicResource Text}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,4" Margin="0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NeedsInput}" Value="True">
                                            <Setter Property="Background" Value="#30FFA726"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ParamDisplayName}"
                                           Foreground="{DynamicResource Text}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ParamDisplayName}"/>

                                <!-- Bound parameter display -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BindingDisplayText}"
                                           Foreground="#FF808080"
                                           FontStyle="Italic"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsBound, Converter={StaticResource BoolToVis}}"/>

                                <!-- String/Int/Double input -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding IsStringInput, Converter={StaticResource BoolToVis}}"/>

                                <!-- Bool input -->
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding BoolValue}"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource Text}"
                                          Visibility="{Binding IsBoolInput, Converter={StaticResource BoolToVis}}"/>

                                <!-- Enum input -->
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding EnumChoices}"
                                          SelectedItem="{Binding SelectedEnumValue}"
                                          Style="{StaticResource ModernDarkComboBox}"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsEnumInput, Converter={StaticResource BoolToVis}}"/>

                                <!-- Special type display -->
                                <TextBlock Grid.Column="1"
                                           Text="(configured automatically)"
                                           Foreground="#FF808080"
                                           FontStyle="Italic"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSpecialType, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
