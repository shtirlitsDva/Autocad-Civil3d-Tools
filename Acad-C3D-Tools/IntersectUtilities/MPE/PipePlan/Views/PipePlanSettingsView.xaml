<UserControl x:Class="IntersectUtilities.MPE.PipePlan.Views.PipePlanSettingsView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignWidth="380" d:DesignHeight="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <GroupBox Header="Status">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Header="Straight snap tolerance">
                <TextBox Text="{Binding StraightSnapTolerance, UpdateSourceTrigger=LostFocus}" />
            </GroupBox>

            <GroupBox Header="ProjekteringsRadius pr. dimension">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dimension" Style="{StaticResource LabelStyle}" />
                        <TextBlock Grid.Column="1" Text="Radius" Style="{StaticResource LabelStyle}" />
                        <TextBlock Grid.Column="2" Text="Kilde" Style="{StaticResource LabelStyle}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding RadiusText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="4,0"
                                             HorizontalContentAlignment="Right" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SourceLabel}"
                                               Foreground="{Binding SourceColor}"
                                               VerticalAlignment="Center"
                                               Margin="4,0" />
                                    <Button Grid.Column="3"
                                            Content="Reset"
                                            Height="26"
                                            Padding="8,2"
                                            Command="{Binding DataContext.ResetRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </GroupBox>

            <UniformGrid Columns="2" Margin="0,8,0,0">
                <Button Content="Reload"
                        Margin="0,0,4,0"
                        Command="{Binding ReloadCommand}" />
                <Button Content="Save"
                        Margin="4,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" />
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>

</UserControl>
