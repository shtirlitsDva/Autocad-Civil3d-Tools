<UserControl x:Class="IntersectUtilities.MPE.PipePlanDE.Views.PipePlanDESettingsView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignWidth="900" d:DesignHeight="620">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <GroupBox Header="Status">
                <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Header="Parametertabel (m)">
                <DockPanel>
                    <!-- Action buttons pinned to the bottom, full width under both columns. -->
                    <UniformGrid DockPanel.Dock="Bottom" Columns="2" Margin="0,8,0,0">
                        <Button Content="Nulstil alle"
                                Margin="0,0,4,0"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ResetAllCommand}" />
                        <Button Content="Gem"
                                Margin="4,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </UniformGrid>

                    <!-- Table (left, natural width) sits next to the Regel-Grabenprofil
                         reference (right, fills the remaining palette width). -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="TableScroll"
                                  Grid.Column="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Header row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="DN" Width="64" Style="{StaticResource LabelStyle}" />
                                <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Width="56"
                                                       TextAlignment="Center"
                                                       Style="{StaticResource LabelStyle}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Data rows -->
                            <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <TextBlock Text="{Binding Label}"
                                                       Width="64"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding SourceColor}" />
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Editable input cell, or a locked/muted cell for the
                                                             computed b / b1 columns (IsComputed = true). -->
                                                        <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsReadOnly="{Binding IsComputed}"
                                                                 Width="56"
                                                                 Margin="1,0"
                                                                 Padding="2,2"
                                                                 FontSize="11"
                                                                 HorizontalContentAlignment="Center">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsComputed}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource SurfacePressedBrush}" />
                                                                            <Setter Property="Foreground" Value="{StaticResource ForegroundMutedBrush}" />
                                                                            <Setter Property="IsTabStop" Value="False" />
                                                                            <Setter Property="ToolTip" Value="Beregnet: z1/z3 + 2·d + x + z2/z4 (låst)" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Regel-Grabenprofil reference: shows what each column (z1, d, x, … b, B, B1)
                         measures. Source set in code-behind from the embedded PNG. Capped to the
                         table's height so the two sit side by side at matching scale. -->
                    <Border Grid.Column="1"
                            Background="White"
                            Margin="8,0,0,0"
                            Padding="4"
                            CornerRadius="2"
                            VerticalAlignment="Top">
                        <Image x:Name="DiagramImage"
                               Stretch="Uniform"
                               MaxHeight="{Binding ActualHeight, ElementName=TableScroll}"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    </Grid>
                </DockPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
