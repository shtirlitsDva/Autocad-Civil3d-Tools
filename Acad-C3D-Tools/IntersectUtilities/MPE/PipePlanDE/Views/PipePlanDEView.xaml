<UserControl x:Class="IntersectUtilities.MPE.PipePlanDE.Views.PipePlanDEView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignWidth="380" d:DesignHeight="560">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <GroupBox Header="Status">
                <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" />
            </GroupBox>

            <GroupBox Header="Dimension">
                <StackPanel>
                    <ComboBox ItemsSource="{Binding Dns}"
                              SelectedItem="{Binding SelectedDn}"
                              DisplayMemberPath="Label" />
                    <Button Content="{Binding AdvancedButtonText}"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Padding="10,3"
                            Command="{Binding ToggleAdvancedCommand}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Parametertabel (m)" Visibility="{Binding AdvancedVisibility}">
                <StackPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Header row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="DN" Width="64" Style="{StaticResource LabelStyle}" />
                                <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Width="56"
                                                       TextAlignment="Center"
                                                       Style="{StaticResource LabelStyle}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Data rows -->
                            <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <TextBlock Text="{Binding Label}"
                                                       Width="64"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding SourceColor}" />
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                                                 Width="56"
                                                                 Margin="1,0"
                                                                 Padding="2,2"
                                                                 FontSize="11"
                                                                 HorizontalContentAlignment="Center" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <Button Content="Nulstil alle"
                                Margin="0,0,4,0"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ResetAllCommand}" />
                        <Button Content="Gem"
                                Margin="4,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </UniformGrid>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
