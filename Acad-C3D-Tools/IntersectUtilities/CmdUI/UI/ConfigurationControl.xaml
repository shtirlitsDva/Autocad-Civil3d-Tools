<UserControl x:Class="IntersectUtilities.CmdUI.UI.ConfigurationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:IntersectUtilities.CmdUI.UI"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             d:Background="{DynamicResource Background}">
    <UserControl.Resources>
        <ResourceDictionary Source="Theme.xaml"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource DarkHeaderBackground}" Padding="10,8">
            <TextBlock Text="CSV Configuration" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Foreground="{DynamicResource Text}"/>
        </Border>

        <!-- Configuration Selection -->
        <GroupBox Grid.Row="1" 
                  Header="Active Configuration" 
                  Margin="10,10,10,5"
                  Style="{StaticResource ModernGroupBox}">
            <StackPanel Orientation="Vertical" Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="Configuration:"
                           Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center"
                           Width="100"/>
                    <ComboBox x:Name="ConfigurationDropdown"
                              Width="150"
                              Style="{StaticResource ModernDarkComboBox}"
                              ItemsSource="{Binding AvailableConfigurations}"
                              SelectedItem="{Binding SelectedConfiguration, Mode=TwoWay}"/>
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Margin="8,0,0,0"
                            Padding="10,3"
                            VerticalAlignment="Center"
                            Background="{DynamicResource DarkRowBackground}"
                            Foreground="{DynamicResource Text}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            ToolTip="Re-scan the Conf folder and re-validate the selected configuration."/>
                </StackPanel>

                <!-- Status indicator: green = complete, orange = none selected, red = incomplete.
                     Text comes from the ViewModel (StatusMessage); the local style only maps the
                     severity flags to a colour. -->
                <TextBlock x:Name="StatusText"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding StatusMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfigurationMissing}" Value="True">
                                    <Setter Property="Foreground" Value="#FFFF9800"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsConfigurationError}" Value="True">
                                    <Setter Property="Foreground" Value="#FFF44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </GroupBox>

        <!-- Information panel -->
        <GroupBox Grid.Row="2" 
                  Header="Information" 
                  Margin="10,5,10,10"
                  Style="{StaticResource ModernGroupBox}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <TextBlock TextWrapping="Wrap" 
                               Foreground="{DynamicResource Text}"
                               FontSize="12"
                               Margin="0,0,0,10">
                        <Run FontWeight="SemiBold">CSV Data Configurations</Run>
                        <LineBreak/>
                        <LineBreak/>
                        Select a configuration to determine which version of CSV files will be used by commands.
                        <LineBreak/>
                        <LineBreak/>
                        • <Run FontWeight="SemiBold">DKv1</Run>: Uses .DKv1.csv files (e.g., Krydsninger.DKv1.csv)
                        <LineBreak/>
                        • <Run FontWeight="SemiBold">DKv2</Run>: Uses .DKv2.csv files (e.g., Krydsninger.DKv2.csv)
                        <LineBreak/>
                        • <Run FontWeight="SemiBold">DEv1</Run>: Uses .DEv1.csv files (e.g., Krydsninger.DEv1.csv)
                        <LineBreak/>
                        <LineBreak/>
                        Distances and Dybde are configuration-aware with fallback: a dedicated file
                        (e.g., Distances.DEv1.csv) is used when present, otherwise the shared
                        unversioned file (Distances.csv, Dybde.csv) is used.
                        <LineBreak/>
                        <LineBreak/>
                        Configurations are discovered from the file names in the Conf folder, so a new
                        configuration appears automatically once its files are added. A configuration
                        whose required versioned files (Krydsninger, Lag-Ler) are missing is still
                        listed, but selecting it shows a red warning here and commands will fail until
                        the missing file is added (or an unversioned fallback is provided). Configuration
                        names must not contain '.' (use 'DEv1', not 'DE.v1'); a dotted name is flagged
                        invalid and ignored, without affecting other configurations. Use Refresh after
                        changing files in the folder.
                        <LineBreak/>
                        <LineBreak/>
                        <Run FontStyle="Italic" Foreground="#FFB0B0B0">
                            Note: Your selection is automatically saved and will be restored next time you start AutoCAD.
                        </Run>
                    </TextBlock>

                    <TextBlock Text="CSV Files Location:" 
                               Foreground="{DynamicResource Text}"
                               FontWeight="SemiBold"
                               Margin="0,10,0,5"/>
                    <TextBox Text="X:\AutoCAD DRI - 01 Civil 3D\Conf"
                             IsReadOnly="True"
                             Background="{DynamicResource DarkRowBackground}"
                             Foreground="{DynamicResource Text}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Padding="5,3"/>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</UserControl>
