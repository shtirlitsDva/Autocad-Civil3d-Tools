<Window x:Class="IntersectUtilities.GraphWriteV2.Theming.UI.LabelThemeDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:IntersectUtilities.GraphWriteV2.Theming.UI"
        xmlns:theming="clr-namespace:IntersectUtilities.GraphWriteV2.Theming"
        Title="Label Theme Designer" Height="720" Width="1120"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        Background="#202020" MinWidth="900" MinHeight="560"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ui:HexToBrushConverter x:Key="Hex"/>
        <ui:EnumBooleanConverter x:Key="Enum"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9d9d9d"/>
            <Setter Property="Margin" Value="0,22,0,11"/>
        </Style>

        <!-- Selectable label-style row -->
        <Style x:Key="StyleRow" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,7"/>
            <Setter Property="Foreground" Value="#dcdcdc"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="7" Padding="11,9" BorderThickness="1"
                                Background="#2c2c2c" BorderBrush="#343434">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#10314d"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#2f6ca6"/>
                                <Setter Property="Foreground" Value="#d4ebff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="#4a5159"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Palette card -->
        <Style x:Key="PaletteCard" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#dcdcdc"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="7" Padding="8,8" BorderThickness="1"
                                Background="#2c2c2c" BorderBrush="#343434">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#10314d"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#2f6ca6"/>
                                <Setter Property="Foreground" Value="#d4ebff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented control segment -->
        <Style x:Key="Seg" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#b5b5b5"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="4" Padding="8,6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0e639c"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill toggle -->
        <Style x:Key="Pill" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Width="40" Height="22" CornerRadius="11" Background="#5a5a5a">
                            <Ellipse x:Name="knob" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#4cc2ff"/>
                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="knob" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color swatch button -->
        <Style x:Key="Swatch" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" BorderThickness="1" BorderBrush="#4a4a4a"
                                Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary / primary footer buttons -->
        <Style x:Key="Secondary" TargetType="Button">
            <Setter Property="Foreground" Value="#dcdcdc"/>
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#4a4a4a"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource Secondary}">
            <Setter Property="Foreground" Value="#04131a"/>
            <Setter Property="Background" Value="#4cc2ff"/>
            <Setter Property="BorderBrush" Value="#4cc2ff"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
        </Style>

        <!-- Title bar glyph button -->
        <Style x:Key="Glyph" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Foreground" Value="#cfcfcf"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark combo box -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#4a4a4a"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="tb" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="5" BorderThickness="1" BorderBrush="#4a4a4a" Background="#3a3a3a">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,24,0" VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M0,0 L4,4 L8,0 Z" Fill="#cfcfcf"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2c2c2c" BorderBrush="#4a4a4a" BorderThickness="1" CornerRadius="5">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#10314d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark slider -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#3a3a3a"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#4cc2ff"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#dcdcdc"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="HexText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7a7a7a"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="#2b2b2b" BorderBrush="#1c1c1c" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4cc2ff" Offset="0"/>
                                <GradientStop Color="#2dd4bf" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="L" Foreground="#04131a" FontWeight="Bold" FontSize="9"
                                   FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Label Theme Designer" Foreground="#cfcfcf" FontSize="12.5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="— GRAPHWRITEV2" Foreground="#6e6e6e" FontSize="12.5" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource Glyph}" Content="—" FontSize="13" Click="Minimize_Click"/>
                    <Button Style="{StaticResource Glyph}" Content="◻" FontSize="11" Click="Maximize_Click"/>
                    <Button Style="{StaticResource Glyph}" Content="✕" FontSize="12" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="354"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT CONTROLS -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#1b1b1b" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,24">
                    <StackPanel>
                        <!-- Label Style -->
                        <TextBlock Text="LABEL STYLE" Style="{StaticResource SectionHeader}" Margin="0,0,0,11"/>
                        <RadioButton GroupName="style" Style="{StaticResource StyleRow}"
                                     IsChecked="{Binding Style, Converter={StaticResource Enum}, ConverterParameter=Glass}">
                            <DockPanel><TextBlock Text="Glass HUD" FontWeight="SemiBold" FontSize="13"/><TextBlock Text="rounded glass" Opacity="0.65" FontSize="11" HorizontalAlignment="Right"/></DockPanel>
                        </RadioButton>
                        <RadioButton GroupName="style" Style="{StaticResource StyleRow}"
                                     IsChecked="{Binding Style, Converter={StaticResource Enum}, ConverterParameter=Blueprint}">
                            <DockPanel><TextBlock Text="Blueprint Grid" FontWeight="SemiBold" FontSize="13"/><TextBlock Text="schematic" Opacity="0.65" FontSize="11" HorizontalAlignment="Right"/></DockPanel>
                        </RadioButton>
                        <RadioButton GroupName="style" Style="{StaticResource StyleRow}"
                                     IsChecked="{Binding Style, Converter={StaticResource Enum}, ConverterParameter=Segmented}">
                            <DockPanel><TextBlock Text="Segmented Tiles" FontWeight="SemiBold" FontSize="13"/><TextBlock Text="modular" Opacity="0.65" FontSize="11" HorizontalAlignment="Right"/></DockPanel>
                        </RadioButton>
                        <RadioButton GroupName="style" Style="{StaticResource StyleRow}"
                                     IsChecked="{Binding Style, Converter={StaticResource Enum}, ConverterParameter=Fluent}">
                            <DockPanel><TextBlock Text="Fluent Acrylic" FontWeight="SemiBold" FontSize="13"/><TextBlock Text="frosted" Opacity="0.65" FontSize="11" HorizontalAlignment="Right"/></DockPanel>
                        </RadioButton>
                        <RadioButton GroupName="style" Style="{StaticResource StyleRow}"
                                     IsChecked="{Binding Style, Converter={StaticResource Enum}, ConverterParameter=Terminal}">
                            <DockPanel><TextBlock Text="Tactical Terminal" FontWeight="SemiBold" FontSize="13"/><TextBlock Text="mono" Opacity="0.65" FontSize="11" HorizontalAlignment="Right"/></DockPanel>
                        </RadioButton>

                        <!-- Tile treatment (Segmented only) -->
                        <Border Margin="0,12,0,0" Background="#2c2c2c" BorderBrush="#383838" BorderThickness="1" CornerRadius="7" Padding="11,11"
                                Visibility="{Binding IsSegmented, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="TILE TREATMENT" Foreground="#9d9d9d" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Border Background="#1f1f1f" CornerRadius="6" Padding="3">
                                    <UniformGrid Rows="1">
                                        <RadioButton GroupName="tile" Style="{StaticResource Seg}" Content="Flush"
                                                     IsChecked="{Binding TileMode, Converter={StaticResource Enum}, ConverterParameter=Flush}"/>
                                        <RadioButton GroupName="tile" Style="{StaticResource Seg}" Content="Cells pop"
                                                     IsChecked="{Binding TileMode, Converter={StaticResource Enum}, ConverterParameter=Pop}"/>
                                        <RadioButton GroupName="tile" Style="{StaticResource Seg}" Content="Bordered"
                                                     IsChecked="{Binding TileMode, Converter={StaticResource Enum}, ConverterParameter=Bordered}"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Palette -->
                        <TextBlock Text="PALETTE" Style="{StaticResource SectionHeader}"/>
                        <UniformGrid Columns="2" Rows="2">
                            <RadioButton GroupName="pal" Style="{StaticResource PaletteCard}" Margin="0,0,4,4"
                                         IsChecked="{Binding Preset, Mode=OneWay, Converter={StaticResource Enum}, ConverterParameter=Cyan}"
                                         Command="{Binding SelectPresetCommand}" CommandParameter="{x:Static theming:PalettePreset.Cyan}">
                                <StackPanel Orientation="Horizontal"><Border Width="15" Height="15" CornerRadius="4" Background="#48d6e8"/><TextBlock Text="Cyan Ice" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12.5"/></StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="pal" Style="{StaticResource PaletteCard}" Margin="4,0,0,4"
                                         IsChecked="{Binding Preset, Mode=OneWay, Converter={StaticResource Enum}, ConverterParameter=Amber}"
                                         Command="{Binding SelectPresetCommand}" CommandParameter="{x:Static theming:PalettePreset.Amber}">
                                <StackPanel Orientation="Horizontal"><Border Width="15" Height="15" CornerRadius="4" Background="#e0a536"/><TextBlock Text="Amber" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12.5"/></StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="pal" Style="{StaticResource PaletteCard}" Margin="0,4,4,0"
                                         IsChecked="{Binding Preset, Mode=OneWay, Converter={StaticResource Enum}, ConverterParameter=Emerald}"
                                         Command="{Binding SelectPresetCommand}" CommandParameter="{x:Static theming:PalettePreset.Emerald}">
                                <StackPanel Orientation="Horizontal"><Border Width="15" Height="15" CornerRadius="4" Background="#34c98a"/><TextBlock Text="Emerald" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12.5"/></StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="pal" Style="{StaticResource PaletteCard}" Margin="4,4,0,0"
                                         IsChecked="{Binding Preset, Mode=OneWay, Converter={StaticResource Enum}, ConverterParameter=Violet}"
                                         Command="{Binding SelectPresetCommand}" CommandParameter="{x:Static theming:PalettePreset.Violet}">
                                <StackPanel Orientation="Horizontal"><Border Width="15" Height="15" CornerRadius="4" Background="#a855f7"/><TextBlock Text="Violet" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12.5"/></StackPanel>
                            </RadioButton>
                        </UniformGrid>
                        <TextBlock Margin="0,9,0,0" FontSize="11" Foreground="#7a7a7a">
                            <Run Text="Active: "/><Run Text="{Binding PresetName, Mode=OneWay}" Foreground="#cfcfcf" FontWeight="SemiBold"/>
                        </TextBlock>

                        <!-- Colors -->
                        <TextBlock Text="COLORS" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Frame -->
                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource Swatch}" Margin="0,0,0,9" Tag="Frame" Click="Swatch_Click" Background="{Binding Frame, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Frame" Style="{StaticResource ColorLabel}" Margin="11,0,0,9"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Frame}" Style="{StaticResource HexText}" Margin="0,0,0,9"/>
                            <!-- Panel top -->
                            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource Swatch}" Margin="0,0,0,9" Tag="Fill1" Click="Swatch_Click" Background="{Binding Fill1, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Panel ▲" Style="{StaticResource ColorLabel}" Margin="11,0,0,9"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Fill1}" Style="{StaticResource HexText}" Margin="0,0,0,9"/>
                            <!-- Panel bottom -->
                            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource Swatch}" Margin="0,0,0,9" Tag="Fill2" Click="Swatch_Click" Background="{Binding Fill2, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Panel ▼" Style="{StaticResource ColorLabel}" Margin="11,0,0,9"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Fill2}" Style="{StaticResource HexText}" Margin="0,0,0,9"/>
                            <!-- ID -->
                            <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource Swatch}" Margin="0,0,0,9" Tag="IdColor" Click="Swatch_Click" Background="{Binding IdColor, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="ID text" Style="{StaticResource ColorLabel}" Margin="11,0,0,9"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding IdColor}" Style="{StaticResource HexText}" Margin="0,0,0,9"/>
                            <!-- Body -->
                            <Button Grid.Row="4" Grid.Column="0" Style="{StaticResource Swatch}" Margin="0,0,0,9" Tag="BodyColor" Click="Swatch_Click" Background="{Binding BodyColor, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Body text" Style="{StaticResource ColorLabel}" Margin="11,0,0,9"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding BodyColor}" Style="{StaticResource HexText}" Margin="0,0,0,9"/>
                            <!-- Divider -->
                            <Button Grid.Row="5" Grid.Column="0" Style="{StaticResource Swatch}" Tag="Divider" Click="Swatch_Click" Background="{Binding Divider, Converter={StaticResource Hex}}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Divider" Style="{StaticResource ColorLabel}" Margin="11,0,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Divider}" Style="{StaticResource HexText}"/>
                        </Grid>

                        <!-- Series numerals -->
                        <TextBlock Text="SERIES NUMERALS" Style="{StaticResource SectionHeader}"/>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Show on labels" Style="{StaticResource ColorLabel}"/>
                            <CheckBox Style="{StaticResource Pill}" HorizontalAlignment="Right" IsChecked="{Binding ShowSeries}"/>
                        </DockPanel>
                        <Grid Margin="0,0,0,11">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="9"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CHIP" Foreground="#8a8a8a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Border Background="#1f1f1f" CornerRadius="6" Padding="3">
                                    <UniformGrid Rows="1">
                                        <RadioButton GroupName="chipfill" Style="{StaticResource Seg}" Content="Filled" IsChecked="{Binding ChipFilled}"/>
                                        <RadioButton GroupName="chipfill" Style="{StaticResource Seg}" Content="Outline" IsChecked="{Binding ChipFilled, Converter={StaticResource Enum}, ConverterParameter=False}"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="POSITION" Foreground="#8a8a8a" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Border Background="#1f1f1f" CornerRadius="6" Padding="3">
                                    <UniformGrid Rows="1">
                                        <RadioButton GroupName="chippos" Style="{StaticResource Seg}" Content="After" IsChecked="{Binding ChipBefore, Converter={StaticResource Enum}, ConverterParameter=False}"/>
                                        <RadioButton GroupName="chippos" Style="{StaticResource Seg}" Content="Before" IsChecked="{Binding ChipBefore}"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource Swatch}" Width="30" Height="24" Tag="Series1" Click="Swatch_Click" Background="{Binding Series1, Converter={StaticResource Hex}}"/>
                            <TextBlock Text="I" Foreground="#bdbdbd" FontFamily="Consolas" FontWeight="SemiBold" FontSize="11" Margin="8,0,14,0" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource Swatch}" Width="30" Height="24" Tag="Series2" Click="Swatch_Click" Background="{Binding Series2, Converter={StaticResource Hex}}"/>
                            <TextBlock Text="II" Foreground="#bdbdbd" FontFamily="Consolas" FontWeight="SemiBold" FontSize="11" Margin="8,0,14,0" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource Swatch}" Width="30" Height="24" Tag="Series3" Click="Swatch_Click" Background="{Binding Series3, Converter={StaticResource Hex}}"/>
                            <TextBlock Text="III" Foreground="#bdbdbd" FontFamily="Consolas" FontWeight="SemiBold" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Typography -->
                        <TextBlock Text="TYPOGRAPHY" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="ID font (monospace)" Foreground="#9d9d9d" FontSize="11" Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkCombo}" ItemContainerStyle="{StaticResource DarkComboItem}" SelectedValue="{Binding IdFont}" SelectedValuePath="Content">
                            <ComboBoxItem Content="Courier New"/><ComboBoxItem Content="Consolas"/><ComboBoxItem Content="Cascadia Mono"/><ComboBoxItem Content="Lucida Console"/>
                        </ComboBox>
                        <TextBlock Text="Body font" Foreground="#9d9d9d" FontSize="11" Margin="0,9,0,5"/>
                        <ComboBox Style="{StaticResource DarkCombo}" ItemContainerStyle="{StaticResource DarkComboItem}" SelectedValue="{Binding BodyFont}" SelectedValuePath="Content">
                            <ComboBoxItem Content="Helvetica"/><ComboBoxItem Content="Segoe UI"/><ComboBoxItem Content="Arial"/><ComboBoxItem Content="Verdana"/>
                        </ComboBox>

                        <!-- Layout -->
                        <TextBlock Text="LAYOUT" Style="{StaticResource SectionHeader}"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Cell padding" Style="{StaticResource ColorLabel}"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#8a8a8a" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center">
                                <Run Text="{Binding Padding}"/><Run Text=" pt"/>
                            </TextBlock>
                        </DockPanel>
                        <Slider Style="{StaticResource DarkSlider}" Minimum="4" Maximum="14" Value="{Binding Padding}"
                                IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <DockPanel Margin="0,14,0,0">
                            <TextBlock Text="Rounded corners" Style="{StaticResource ColorLabel}"/>
                            <CheckBox Style="{StaticResource Pill}" HorizontalAlignment="Right" IsChecked="{Binding Rounded}"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT PREVIEW -->
            <Grid Grid.Column="1" Background="#161616">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#242424" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Ellipse Width="7" Height="7" Fill="#2dd4bf"/>
                        <TextBlock Text="Live preview · Graphviz output" Foreground="#bdbdbd" FontSize="12" Margin="9,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1">
                    <Border.Background>
                        <RadialGradientBrush GradientOrigin="0.5,0.4" Center="0.5,0.4" RadiusX="0.6" RadiusY="0.6">
                            <GradientStop Color="#1c1c1c" Offset="0"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Image Source="{Binding PreviewImage}" Stretch="None"
                               HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding PreviewError}" Foreground="#fb7185" FontFamily="Consolas" FontSize="12"
                                   TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" BorderBrush="#242424" BorderThickness="0,1,0,0" Padding="16,9">
                    <DockPanel>
                        <TextBlock Text="{Binding Toast}" Foreground="#5eead4" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Copy DOT" Command="{Binding CopyDotCommand}"
                                Foreground="#9cd4ff" Background="Transparent" BorderBrush="#2f4a63" Style="{StaticResource Secondary}" Padding="11,5" FontSize="11.5"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#252526" BorderBrush="#1b1b1b" BorderThickness="0,1,0,0">
            <DockPanel Margin="18,0">
                <Button DockPanel.Dock="Left" Content="↺  Reset to preset" Command="{Binding ResetCommand}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Foreground="#bdbdbd" Background="Transparent" BorderBrush="Transparent" Style="{StaticResource Secondary}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Export theme…" Style="{StaticResource Secondary}" Margin="0,0,10,0" Click="Export_Click"/>
                    <Button Content="Cancel" Style="{StaticResource Secondary}" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button Content="Apply" Style="{StaticResource Primary}" Click="Apply_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
