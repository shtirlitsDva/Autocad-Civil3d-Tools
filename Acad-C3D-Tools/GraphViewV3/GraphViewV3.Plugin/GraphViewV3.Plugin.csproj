<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <NoWarn>$(NoWarn);CA1416</NoWarn>
    <RootNamespace>GraphViewV3</RootNamespace>
    <AssemblyName>GraphViewV3.Plugin</AssemblyName>
    <AutoCADPath Condition="'$(AutoCADPath)' == ''">C:\Program Files\Autodesk\AutoCAD 2025</AutoCADPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="accoremgd"><HintPath>$(AutoCADPath)\accoremgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="acdbmgd"><HintPath>$(AutoCADPath)\acdbmgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="acmgd"><HintPath>$(AutoCADPath)\acmgd.dll</HintPath><Private>False</Private></Reference>
    <!-- Civil 3D / AEC / Map — needed by the imported UtilitiesCommonSHARED FJV domain. -->
    <Reference Include="AecBaseMgd"><HintPath>$(AutoCADPath)\ACA\AecBaseMgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="AecPropDataMgd"><HintPath>$(AutoCADPath)\ACA\AecPropDataMgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="AecArchMgd"><HintPath>$(AutoCADPath)\ACA\AecArchMgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="AeccDbMgd"><HintPath>$(AutoCADPath)\C3D\AeccDbMgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="AeccDataShortcutMgd"><HintPath>$(AutoCADPath)\C3D\AeccDataShortcutMgd.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="ManagedMapApi"><HintPath>$(AutoCADPath)\Map\ManagedMapApi.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="AcMr"><HintPath>$(AutoCADPath)\AcMr.DLL</HintPath><Private>False</Private></Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="morelinq" Version="4.3.0" />
  </ItemGroup>

  <!-- UseWindowsForms adds WinForms + System.Drawing to global usings, which clash with the
       WPF UI types. Drop them; the shared files that need WinForms have explicit usings. -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GraphViewV3.Core\GraphViewV3.Core.csproj" />
  </ItemGroup>

  <!-- Shared AcadEventManager (compiled in; reload-safe, no separate DLL) -->
  <Import Project="..\..\EventManager\EventManager.projitems" Label="Shared" />

  <!-- FJV domain: authoritative pipe/block detection. UtilitiesCommonSHARED provides
       UtilsCommon (enums, Csv, Utils) + ComponentSchedule.GetPipeTypeEnum; PipeScheduleV2
       is a single file linked in for GetPipeSystem. -->
  <Import Project="..\..\UtilitiesCommonSHARED\UtilitiesCommonSHARED.projitems" Label="Shared" />
  <Import Project="..\..\FormsSHARED\FormsSHARED.projitems" Label="Shared" />
  <ItemGroup>
    <Compile Include="..\..\IntersectUtilities\PipeScheduleV2\PipeScheduleV2.cs" Link="Linked\PipeScheduleV2.cs" />
  </ItemGroup>

</Project>
