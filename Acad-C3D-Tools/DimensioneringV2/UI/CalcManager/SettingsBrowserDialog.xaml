<Window x:Class="DimensioneringV2.UI.CalcManager.SettingsBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beregningsindstillinger (skrivebeskyttet)"
        Height="500" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#FF2D3442">
    <Window.Resources>
        <ResourceDictionary Source="../Theme.xaml"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="#FF2D3442"
                    Foreground="White"
                    BorderBrush="#FF5A6A80">
            <TabItem Header="Generelt">
                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          ItemsSource="{Binding GeneralSettings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Indstilling" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="V&#230;rdi" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Ruhed">
                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          ItemsSource="{Binding RoughnessSettings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Indstilling" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="V&#230;rdi" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Beregning">
                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          ItemsSource="{Binding CalculationSettings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Indstilling" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="V&#230;rdi" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="R&#248;rtyper">
                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          ItemsSource="{Binding PipeSettings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Indstilling" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="V&#230;rdi" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Luk" Width="80" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
