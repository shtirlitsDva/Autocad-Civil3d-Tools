<Window x:Class="DimensioneringV2.UI.CalcManager.CalcManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beregningsmanager" Height="350" Width="750"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#FF2D3442">
    <Window.Resources>
        <ResourceDictionary Source="../Theme.xaml"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  Style="{StaticResource DarkDataGridStyle}"
                  ItemsSource="{Binding Networks}"
                  SelectedItem="{Binding SelectedNetwork, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Gennemse indstillinger"
                              Command="{Binding BrowseSettingsCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Navn" Binding="{Binding Id}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Dato" Binding="{Binding CalculatedAt, StringFormat='{}{0:dd-MM-yyyy HH:mm}'}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Beregningstid" Binding="{Binding Duration}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Pris (kr)" Binding="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Beskrivelse" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Importer" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ImportCommand}"/>
                <Button Content="Eksporter" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ExportCommand}"/>
                <Button Content="DIMS" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ExportDimsCommand}"/>
                <Button Content="Til DWG" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding WriteToDwgCommand}"/>
                <Button Content="Rapport" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding GenerateReportCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Indlæs" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding LoadCommand}"/>
                <Button Content="Gem" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Slet" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding DeleteCommand}"/>
                <Button Content="Luk" Padding="12,4" Click="CloseButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
