<Window x:Class="DimensioneringV2.UI.CalcManager.CalcManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beregningsmanager" Height="350" Width="750"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#FF2D3442">
    <Window.Resources>
        <ResourceDictionary Source="../Theme.xaml"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  Style="{StaticResource DarkDataGridStyle}"
                  ItemsSource="{Binding Networks}"
                  SelectedItem="{Binding SelectedNetwork, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Gennemse indstillinger"
                              Command="{Binding BrowseSettingsCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Navn" Binding="{Binding Id}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Dato" Binding="{Binding CalculatedAt, StringFormat='{}{0:dd-MM-yyyy HH:mm}'}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Beregningstid" Binding="{Binding Duration}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Pris (kr)" Binding="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Beskrivelse" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Indlæs" Width="80" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding LoadCommand}"/>
            <Button Content="Gem" Width="80" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Slet" Width="80" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding DeleteCommand}"/>
            <Button Content="Luk" Width="80" Click="CloseButton_Click"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
