<Window x:Class="DimensioneringV2.UI.ReportSettings.HnSettingsPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vælg beregning at kopiere fra"
        Height="380" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FF2D3442">
    <Window.Resources>
        <ResourceDictionary Source="../Theme.xaml"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- HN list -->
            <ListBox Grid.Column="0" x:Name="LbNetworks" Margin="0,0,8,0"
                     SelectionChanged="LbNetworks_SelectionChanged"
                     DisplayMemberPath="Id"/>

            <!-- Preview panel -->
            <Border Grid.Column="1" BorderBrush="#FF5A6A80" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <StackPanel x:Name="PreviewPanel">
                    <TextBlock Text="Forhåndsvisning" FontWeight="SemiBold"
                               Foreground="#FFA0AEC0" FontSize="11" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TbPreview" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Vælg" Style="{StaticResource DialogButtonStyle}"
                    x:Name="BtnSelect" Click="SelectButton_Click" IsEnabled="False"/>
            <Button Content="Annuller" Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
